# ---- LLM ----
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Primary model used by the orchestrator
AGENTMESH_PLANNER_MODEL=claude-sonnet-4-5

# Critic model (can be the same, or a smaller/cheaper one)
AGENTMESH_CRITIC_MODEL=claude-sonnet-4-5

# Generation params
AGENTMESH_MAX_TOKENS=2048
AGENTMESH_TEMPERATURE=0.2

# ---- Memory backends ----
# Redis for episodic memory
REDIS_URL=redis://localhost:6379/0

# Chroma persistent directory for semantic memory
CHROMA_PERSIST_DIR=./data/chroma

# Procedural memory JSON file
PROCEDURAL_STORE_PATH=./data/procedural.json

# ---- Runtime ----
AGENTMESH_MAX_STEPS=12          # hard cap on tool-call iterations per task
AGENTMESH_CRITIC_ENABLED=true   # disable to benchmark ablation
AGENTMESH_LOG_LEVEL=INFO

# ---- API server ----
AGENTMESH_HOST=0.0.0.0
AGENTMESH_PORT=8000
